{
  "expo": {
    "name": "LockIn",
    "slug": "lockin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lockin",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080b10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.piyushbhalwalkar.lockin",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080b10"
      },
      "package": "com.piyushbhalwalkar.lockin"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2999782b-9c6b-41c0-bdd1-b2fb244c6e3f"
      }
    }
  }
}
