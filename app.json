{
  "expo": {
    "name": "LockIn",
    "slug": "lock-in",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lockin",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080b10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.piyushbhalwalkar.lockin",
      "infoPlist": {
        "NSMotionUsageDescription": "LockIn uses motion data to automatically count your steps and calculate calories burned throughout the day."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080b10"
      },
      "package": "com.piyushbhalwalkar.lockin",
      "permissions": [
        "ACTIVITY_RECOGNITION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "@react-native-google-signin/google-signin",
      "expo-web-browser",
      [
        "expo-sensors",
        {
          "motionPermission": "LockIn uses motion data to automatically count your steps and calculate calories burned throughout the day."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow LockIn to access your photos.",
          "savePhotosPermission": "Allow LockIn to save workout cards to your photos.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LockIn to access your camera for workout selfies."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a5c0ffd6-8f28-42b2-96e5-d0107e8b6b68"
      }
    }
  }
}